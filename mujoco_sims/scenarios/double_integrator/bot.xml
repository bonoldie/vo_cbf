<!--
    The three slide joints represent the x, y and z coordinates.

    Robot dynamics:
        p_dot = v
        v_dot = u

    Since mass is 1 kg => acceleration == actuator force
-->
<robot>
    <body name="robot" pos="0 0 0">
        <joint
            name="robot_x"
            type="slide"
            axis="1 0 0"
            damping="0" />

        <joint
            name="robot_y"
            type="slide"
            axis="0 1 0"
            damping="0" />

        <joint
            name="robot_z"
            type="slide"
            axis="0 0 1"
            damping="0" />

        <geom
            name="robot_geom"
            type="sphere"
            size="0.10"
            mass="1.0"
            rgba="1.0 0.20 0.15 1"
            friction="0.4 0.05 0.005" />

        <site
            name="robot_center"
            type="sphere"
            size="0.015"
            rgba="1 1 1 1" />

    </body>
    <!-- Controls are forces [Fx, Fy, Fz]. -->
    <actuator>
        <motor
            name="force_x"
            joint="robot_x"
            gear="1"
            ctrlrange="-5 5" />

        <motor
            name="force_y"
            joint="robot_y"
            gear="1"
            ctrlrange="-5 5" />

        <motor
            name="force_z"
            joint="robot_z"
            gear="1"
            ctrlrange="-5 5" />
    </actuator>
</robot>