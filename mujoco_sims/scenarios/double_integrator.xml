<mujoco model="double_integrator_3d">
    <compiler autolimits="true" angle="radian" />

    <!-- Zero gravity produces ideal translational double-integrator dynamics. -->
    <option timestep="0.002" gravity="0 0 0" integrator="RK4" />

    <visual>
        <headlight ambient="0.7 0.7 0.7" />
    </visual>

    <asset>
        <texture
            name="grid_texture"
            type="2d"
            builtin="checker"
            rgb1="0.15 0.20 0.25"
            rgb2="0.25 0.30 0.35"
            width="512"
            height="512" />

        <material
            name="grid"
            texture="grid_texture"
            texrepeat="10 10"
            reflectance="0.1" />
    </asset>

    <default>
        <default class="wheel">
            <geom
                type="cylinder"
                size=".03 .01"
                rgba=".5 .5 1 1"
                friction="2.0 0.5 0.01" />
        </default>

        <default class="decor">
            <site type="box" rgba=".5 1 .5 1" />
        </default>

        <default class="obstacle">
            <geom
                type="sphere"
                rgba="0.25 0.45 0.95 1"
                friction="0.8 0.1 0.01" />
        </default>
    </default>

    <worldbody>
        <!-- Floor below the robot, allowing free motion in 3D. -->
        <geom
            name="floor"
            type="plane"
            pos="0 0 -1"
            size="5 5 .01"
            material="grid" />

        <light pos="0 0 5" dir="0 0 -1" />

        <!--
            The three slide joints represent the x, y and z coordinates.

            Robot dynamics:
                p_dot = v
                v_dot = u

            Since mass = 1 kg:
                acceleration = actuator force
        -->
        <body name="robot" pos="0 0 0">
            <joint
                name="robot_x"
                type="slide"
                axis="1 0 0"
                damping="0" />

            <joint
                name="robot_y"
                type="slide"
                axis="0 1 0"
                damping="0" />

            <joint
                name="robot_z"
                type="slide"
                axis="0 0 1"
                damping="0" />

            <geom
                name="robot_geom"
                type="sphere"
                size="0.10"
                mass="1.0"
                rgba="1.0 0.20 0.15 1"
                friction="0.4 0.05 0.005" />

            <site
                name="robot_center"
                type="sphere"
                size="0.015"
                rgba="1 1 1 1" />
        </body>

        <!-- Fixed spherical obstacles. -->

        <body name="obstacle_1" pos="1.00 0.35 0.00">
            <geom
                name="obstacle_1_geom"
                class="obstacle"
                size="0.20" />
        </body>

        <body name="obstacle_2" pos="1.65 -0.55 0.30">
            <geom
                name="obstacle_2_geom"
                class="obstacle"
                size="0.35"
                rgba="0.20 0.75 0.35 1" />
        </body>

        <body name="obstacle_3" pos="0.35 1.25 -0.20">
            <geom
                name="obstacle_3_geom"
                class="obstacle"
                size="0.15"
                rgba="0.95 0.65 0.15 1" />
        </body>

        <body name="obstacle_4" pos="-1.00 1.35 0.45">
            <geom
                name="obstacle_4_geom"
                class="obstacle"
                size="0.30"
                rgba="0.65 0.25 0.85 1" />
        </body>

        <body name="obstacle_5" pos="-1.30 -0.85 -0.25">
            <geom
                name="obstacle_5_geom"
                class="obstacle"
                size="0.25"
                rgba="0.20 0.75 0.80 1" />
        </body>
    </worldbody>

    <!-- Controls are forces [Fx, Fy, Fz]. -->
    <actuator>
        <motor
            name="force_x"
            joint="robot_x"
            gear="1"
            ctrlrange="-5 5" />

        <motor
            name="force_y"
            joint="robot_y"
            gear="1"
            ctrlrange="-5 5" />

        <motor
            name="force_z"
            joint="robot_z"
            gear="1"
            ctrlrange="-5 5" />
    </actuator>

    <sensor>
        <framepos
            name="robot_position"
            objtype="body"
            objname="robot" />

        <framelinvel
            name="robot_velocity"
            objtype="body"
            objname="robot" />
    </sensor>
</mujoco>